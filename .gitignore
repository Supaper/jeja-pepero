# 시크릿 — 절대 커밋 금지
.env
.env.*
*.local

# Firebase 서비스계정 키 (Admin SDK) — 수집기용, 비밀
serviceAccount*.json
*-firebase-adminsdk-*.json
firebase-admin*.json

# 카카오 토큰 등
*token*.json
secrets/

# 실제 운영 설정(실명 명단 등 개인정보 포함 가능) — config.example.yaml 만 커밋
config/config.yaml
config/*.local.yaml

# Firebase CLI 캐시/로그
.firebase/
firebase-debug.log
*.log

# Python (수집기, 추후)
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# OS / 에디터
.DS_Store
.idea/
.vscode/
