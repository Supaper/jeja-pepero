rules_version = '2';

// 접근 경계 = 이 규칙. 클라이언트의 로그인 redirect는 UX 보조일 뿐이다.
// - users/{이메일} 문서가 존재하는 계정만 데이터를 read 할 수 있다(허용목록).
// - 모든 클라이언트 write는 금지. 수집기는 Admin SDK로 규칙을 우회해 기록한다.
// - users 허용목록은 운영자가 Firebase 콘솔/Admin SDK로만 관리한다.
service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인 사용자가 허용목록(users)에 있는지 검사
    function isAllowed() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email));
    }

    // 허용목록: 본인 이메일 문서만 존재 확인용으로 read 허용. write 금지.
    match /users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // 수집 글
    match /posts/{postId} {
      allow read: if isAllowed();
      allow write: if false;
    }

    // 월별 통계
    match /stats/{statId} {
      allow read: if isAllowed();
      allow write: if false;
    }
  }
}
